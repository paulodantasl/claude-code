# Copy to .env and fill in your values.

# Claude API key — enables AI portal extraction, requirements extraction,
# and AI-written proposal drafts. Without it the system still runs and falls
# back to template-based requirements and proposals.
ANTHROPIC_API_KEY=sk-ant-...

# SAM.gov public API key (free) — required for the federal source.
# Sign up: https://api.data.gov/signup/
SAM_GOV_API_KEY=your-sam-gov-key

# Database (default: SQLite file in the working directory)
DATABASE_URL=sqlite:///bids.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/bids

# Where bid package folders are written (default: ./bid_packages)
BID_OUTPUT_DIR=bid_packages

# Slack webhook for qualified-bid alerts (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
