# Copy to .env and fill in your values

# Claude API key (required for AI agent mode)
ANTHROPIC_API_KEY=sk-ant-...

# Database (default: SQLite file in working directory)
DATABASE_URL=sqlite:///permits.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/permits

# Alert channels
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=app-specific-password

# Optional: Socrata app token (raises API rate limit from 1000→unlimited req/day)
SOCRATA_APP_TOKEN=your-socrata-token

# Optional: Accela API token for counties that expose the REST API
ACCELA_API_TOKEN=your-accela-token
