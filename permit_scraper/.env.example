# Copy to .env and fill in your values

# Claude API key (required for AI agent mode)
ANTHROPIC_API_KEY=sk-ant-...

# Database (default: SQLite file in working directory)
DATABASE_URL=sqlite:///permits.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/permits

# Alert channels
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=app-specific-password
# SMTP_FROM=permits@yourcompany.com     # optional; defaults to SMTP_USER

# ── Permit-update monitoring: field-manager SMS notifications ────────────────
# The monitor texts field managers on status changes. Use EITHER a generic SMS
# webhook (any gateway/dispatcher that accepts {to, message, priority}) …
# SMS_WEBHOOK_URL=https://your-sms-gateway.example.com/send
#
# … OR Twilio's REST API:
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_FROM_NUMBER=+13055550100
#
# Generic JSON webhook for the 'webhook' channel (MS Teams / Zapier / your own):
# WEBHOOK_URL=https://your-endpoint.example.com/permit-updates

# Optional: Socrata app token (raises API rate limit from 1000→unlimited req/day)
SOCRATA_APP_TOKEN=your-socrata-token

# Optional: Accela API token for counties that expose the REST API
ACCELA_API_TOKEN=your-accela-token

# ── Google Drive / Sheets export ──────────────────────────────────────────────
# Choose ONE of the two auth methods below:

# Option A — Service Account (recommended for automation / servers)
#   1. Create a Service Account in Google Cloud Console → IAM & Admin
#   2. Grant it "Editor" role, download the JSON key file
#   3. Share your target Drive folder with the service account email
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account-key.json

# Option B — OAuth2 / personal Google account
#   1. Create an "OAuth 2.0 Client ID" (Desktop app) in Google Cloud Console
#   2. Download client_secret.json
#   3. First run will open a browser for consent; token cached automatically
# GOOGLE_OAUTH_CLIENT_FILE=/path/to/client_secret.json

# Optional: Google Drive folder ID to store the spreadsheets and CSV uploads
# (find it in the folder's URL: drive.google.com/drive/folders/<FOLDER_ID>)
# Leave unset to save files to the service account's root Drive
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id
