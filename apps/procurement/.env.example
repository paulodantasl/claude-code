# --- Database ---
DATABASE_URL=postgres://procurement:procurement@localhost:5432/procurement

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Object storage (MinIO, S3-compatible) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=procurement
S3_FORCE_PATH_STYLE=true

# --- Web app ---
NEXTAUTH_URL=http://localhost:3000
SESSION_SECRET=dev-only-change-me-32-bytes-minimum-please

# --- LLM ---
# Leave ANTHROPIC_API_KEY blank to use the stub provider that returns canned answers.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Magic link (dev: logs to console; prod: wire up SMTP/Resend) ---
MAIL_FROM=procurement@example.test
MAIL_TRANSPORT=console
