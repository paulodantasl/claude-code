# --- Database ---
DATABASE_URL=postgres://procurement:procurement@localhost:5432/procurement

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Object storage (MinIO, S3-compatible) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=procurement
S3_FORCE_PATH_STYLE=true

# --- Web app ---
NEXTAUTH_URL=http://localhost:3000
SESSION_SECRET=dev-only-change-me-32-bytes-minimum-please

# --- LLM ---
# Leave ANTHROPIC_API_KEY blank to use the stub provider that returns canned answers.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Mail (magic links + outbound RFQs to vendors) ---
# MAIL_TRANSPORT: console | resend | smtp
#   console — prints messages to the server log (dev only)
#   resend  — uses Resend's API. Set RESEND_API_KEY. Verify your sender domain
#             at https://resend.com/domains first; otherwise MAIL_FROM must be
#             on a verified domain.
#   smtp    — generic SMTP (Postmark, SES, Mailgun, etc.). Set SMTP_HOST/
#             PORT/USER/PASS.
MAIL_FROM=procurement@example.test
MAIL_TRANSPORT=console
MAIL_REPLY_TO=
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
