# Copy to .env (in this folder) and fill in. .env is gitignored — never commit it.

# ── Claude (required for AI scoring + tailoring; optional for lexical-only) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Database (default: SQLite file in the working directory) ────────────────
DATABASE_URL=sqlite:///jobs.db

# ── governmentjobs.com login (ONLY needed for `prefill` browser assist) ─────
# Used solely to log into your own governmentjobs.com account. Never stored,
# logged, or sent anywhere except governmentjobs.com. Leave blank to skip the
# browser assist and just use the tailored packets.
GOVJOBS_USERNAME=you@example.com
GOVJOBS_PASSWORD=your-password

# ── Optional review alerts ──────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=app-specific-password
ALERT_EMAIL_TO=you@gmail.com
